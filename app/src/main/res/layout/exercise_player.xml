<?xml version="1.0" encoding="utf-8"?>
<!-- Aspect-preserving player: texture_view is capturable and composes cleanly;
     resize_mode=fit never stretches or crops (letterboxes if needed). The shutter
     is transparent so the fallback image behind shows through any letterbox bars. -->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:resize_mode="fit"
    app:use_controller="false"
    app:shutter_background_color="@android:color/transparent" />
